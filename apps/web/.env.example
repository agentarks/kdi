# Server-side gate (read by src/hooks.server.ts). Default false.
FF_SVELTEKIT_FRONTEND=true
# Browser-side gate (import.meta.env) shown by FlagBadge. Must be prefixed VITE_.
VITE_FF_SVELTEKIT_FRONTEND=true
# Isolated SQLite DB so the UI never touches the operator's real kdi database.
KDI_DB=/tmp/kdi-ui.sqlite